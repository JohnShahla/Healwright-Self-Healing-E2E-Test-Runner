# Copy to .env and fill in to use the Claude planner.
# Without a key, run with `--planner heuristic` (used by `npm run demo`).
ANTHROPIC_API_KEY=

# Optional: override the model used for planning + healing.
# Default is claude-sonnet-4-6 (fast + cheap, ideal for per-step calls).
# Use claude-opus-4-8 for the hardest semantic-healing cases.
HEALWRIGHT_MODEL=claude-sonnet-4-6
